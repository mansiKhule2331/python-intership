# ─── Django Core ──────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-this-with-a-random-50-char-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ─── Database ─────────────────────────────────────────────────
# Leave blank to use SQLite (development default)
DATABASE_URL=

# For PostgreSQL (production):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# ─── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Email (SMTP) ─────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=NexusCRM <noreply@yourcrm.com>

# ─── JWT ──────────────────────────────────────────────────────
# Access token expiry in hours (default 1)
JWT_ACCESS_TOKEN_LIFETIME_HOURS=1
# Refresh token expiry in days (default 7)
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
